#!/usr/bin/env zsh
# =============================================================================
# llm-server — local LLM server launcher built on top of llama.cpp
#
# COMMANDS
#   setup               Clone/update llama.cpp and build it with GPU support.
#                       On Linux: checks pacman packages, detects CUDA, compiles
#                       for Ryzen 7 5700X + RTX 3070 Ti (SM 8.6).
#                       On macOS: checks Homebrew packages, builds with Metal
#                       (Apple Silicon GPU acceleration).
#
#   benchmark <model>   Measure inference throughput (t/s) for a model.
#                       Starts a temporary server, runs a fixed prompt N times,
#                       and reports tokens/second. If the model has a draft
#                       entry configured, also runs speculative decoding and
#                       reports the speedup. Controlled by:
#                         BENCH_REQUESTS=10   number of timed requests
#                         BENCH_N_PREDICT=256 tokens to generate per request
#
#   router [flags]      Start multi-model router server. Enables running
#                       multiple models simultaneously with API-based routing.
#                       Small model runs on CPU (for autocompletion), big models
#                       run on GPU (for complex tasks). Useful for IDEs like
#                       Continue that need both fast FIM and powerful chat.
#                       Flags: --small, --big, --reasoning, --port, --models-max
#
#   <model>             Start the llama-server for the given model. Downloads
#                       the GGUF file automatically if not present locally.
#
# MODEL FLAGS (for <model> command)
#   --host HOST         Bind address (default: 0.0.0.0)
#   --port N            Override the model's default port
#   --api-key KEY       Require this key on all requests
#   --reasoning         Enable thinking/reasoning mode (Qwen3 family only)
#   --no-reasoning      Disable reasoning mode (default)
#   --draft             Enable speculative decoding with the model's draft model
#   --no-draft          Disable speculative decoding (default)
#   --                  Everything after this is passed directly to llama-server
#
# PERFORMANCE KNOBS (env overrides, tuned for Ryzen 7 5700X)
#   LLAMA_THREADS=8         inference threads (physical core count)
#   LLAMA_THREADS_BATCH=12  batch processing threads
#   LLAMA_THREADS_HTTP=4    HTTP handler threads
#   LLAMA_PARALLEL=2        concurrent inference slots (recommended for 8GB VRAM)
#   LLAMA_CTX_SIZE_QWEN3_5=262144  context for Qwen3.5 Unsloth presets
#   LLAMA_DIR               path to the llama.cpp checkout
#   LLAMA_SERVER            override the llama-server binary path
#
# CONFIGURATION FILE
#   Settings can be configured in ~/.config/llm-server/config.conf
#   Run 'llm-server setup' to create the default config file.
#   Precedence: Environment variables > Config file > Hardcoded defaults
#
# MODEL REGISTRY
#   To add a new model, add entries to:
#     MODEL_ARGS    — llama-server flags (must include -m <path>)
#     MODEL_PORT    — default port
#     MODEL_PATH    — local GGUF path (for existence check / auto-download)
#     MODEL_HF      — "owner/repo filename" on HuggingFace (for download)
#   Optionally, for speculative decoding support:
#     MODEL_DRAFT_PATH — local path for the small draft GGUF
#     MODEL_DRAFT_HF   — "owner/repo filename" for the draft model
#   For reasoning mode support, add the model name to REASONING_MODELS.
# =============================================================================
# Ensure standard utilities are available (dirname, mkdir, etc.)
# This is needed when the script runs in restricted PATH environments
export PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

set -euo pipefail

# =============================================================================
# Configuration file handling
# =============================================================================

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/llm-server"
CONFIG_FILE="$CONFIG_DIR/config.conf"

# Default configuration values
DEFAULT_LLAMA_DIR="$HOME/applications/llama.cpp"
DEFAULT_MODELS_DIR="$HOME/models"
DEFAULT_HOST="0.0.0.0"
DEFAULT_PORT="8084"
DEFAULT_THREADS="8"
DEFAULT_THREADS_BATCH="12"
DEFAULT_THREADS_HTTP="4"
DEFAULT_PARALLEL="8"
DEFAULT_CTX_SIZE_LARGE="65536"
DEFAULT_CTX_SIZE_SMALL="16384"
DEFAULT_CTX_SIZE_QWEN3_5="262144"
DEFAULT_BENCH_REQUESTS="10"
DEFAULT_BENCH_N_PREDICT="256"
DEFAULT_API_KEY=""

# Host-specific defaults
HOSTNAME_SHORT="$(hostname -s 2>/dev/null || hostname)"
if [[ "$HOSTNAME_SHORT" == "donan" ]]; then
  # Ryzen 7 5700X + RTX 3070 Ti (8GB VRAM) tuned defaults
  DEFAULT_PARALLEL="2"
  DEFAULT_CTX_SIZE_LARGE="32768"
fi

# Load configuration from shell-compatible .conf file
# Config file uses simple KEY=VALUE format with variable expansion
load_config() {
  if [[ ! -f "$CONFIG_FILE" ]]; then
    return 0
  fi

  # Source the config file to load variables
  # This allows shell variable expansion like $HOME
  set -a
  if ! source "$CONFIG_FILE"; then
    echo "Error: failed to load config file: $CONFIG_FILE" >&2
    exit 1
  fi
  set +a
}

# Initialize config values (call this after defining the function)
# Keep originals to avoid zsh's built-in HOST leaking into SERVER_HOST defaults.
ORIGINAL_HOST_VAR="${HOST:-}"
ORIGINAL_PORT_VAR="${PORT:-}"
load_config

# Use config values if available, otherwise use defaults
# Environment variables override config values
LLAMA_DIR="${LLAMA_DIR:-${LLAMA_CPP:-$DEFAULT_LLAMA_DIR}}"
MODELS_DIR="${MODELS_DIR:-${MODELS:-$DEFAULT_MODELS_DIR}}"
CONFIG_HOST=""
CONFIG_PORT=""
[[ "${HOST:-}" != "$ORIGINAL_HOST_VAR" ]] && CONFIG_HOST="$HOST"
[[ "${PORT:-}" != "$ORIGINAL_PORT_VAR" ]] && CONFIG_PORT="$PORT"
SERVER_HOST="${SERVER_HOST:-${LLAMA_HOST:-${CONFIG_HOST:-$DEFAULT_HOST}}}"
SERVER_PORT="${SERVER_PORT:-${LLAMA_PORT:-${CONFIG_PORT:-$DEFAULT_PORT}}}"
LLAMA_THREADS="${LLAMA_THREADS:-${THREADS:-$DEFAULT_THREADS}}"
LLAMA_THREADS_BATCH="${LLAMA_THREADS_BATCH:-${THREADS_BATCH:-$DEFAULT_THREADS_BATCH}}"
LLAMA_THREADS_HTTP="${LLAMA_THREADS_HTTP:-${THREADS_HTTP:-$DEFAULT_THREADS_HTTP}}"
LLAMA_PARALLEL="${LLAMA_PARALLEL:-${PARALLEL:-$DEFAULT_PARALLEL}}"
LLAMA_CTX_SIZE_LARGE="${LLAMA_CTX_SIZE_LARGE:-${CTX_SIZE_LARGE:-$DEFAULT_CTX_SIZE_LARGE}}"
LLAMA_CTX_SIZE_SMALL="${LLAMA_CTX_SIZE_SMALL:-${CTX_SIZE_SMALL:-$DEFAULT_CTX_SIZE_SMALL}}"
LLAMA_CTX_SIZE_QWEN3_5="${LLAMA_CTX_SIZE_QWEN3_5:-${CTX_SIZE_QWEN3_5:-$DEFAULT_CTX_SIZE_QWEN3_5}}"
BENCH_REQUESTS="${BENCH_REQUESTS:-${BENCH_REQUESTS_CONF:-$DEFAULT_BENCH_REQUESTS}}"
BENCH_N_PREDICT="${BENCH_N_PREDICT:-${BENCH_N_PREDICT_CONF:-$DEFAULT_BENCH_N_PREDICT}}"
LLAMA_API_KEY="${LLAMA_API_KEY:-${API_KEY:-$DEFAULT_API_KEY}}"

# Router defaults
DEFAULT_ROUTER_SMALL_MODEL="qwen3_5_u08b"
DEFAULT_ROUTER_BIG_MODELS="qwen3_5_u9b,gemma4_e4b,gemma4_e4b_q8"
DEFAULT_ROUTER_MODELS_MAX="4"

ROUTER_SMALL_MODEL="${ROUTER_SMALL_MODEL:-$DEFAULT_ROUTER_SMALL_MODEL}"
ROUTER_BIG_MODELS="${ROUTER_BIG_MODELS:-$DEFAULT_ROUTER_BIG_MODELS}"
ROUTER_MODELS_MAX="${ROUTER_MODELS_MAX:-$DEFAULT_ROUTER_MODELS_MAX}"

# Skip binary detection for setup/profile (binary may not exist yet)
if [[ "${1:-}" != "setup" && "${1:-}" != "profile" ]]; then
  if [[ -n "${LLAMA_SERVER:-}" ]]; then
    : # use env override as-is
  elif command -v llama-server &>/dev/null; then
    LLAMA_SERVER="llama-server"
  elif [[ -x "$LLAMA_DIR/build/bin/llama-server" ]]; then
    LLAMA_SERVER="$LLAMA_DIR/build/bin/llama-server"
  else
    echo "Error: llama-server not found (PATH, $LLAMA_DIR/build/bin/, or \$LLAMA_SERVER)"
    echo "Hint: run 'llm-server setup' to build from source"
    exit 1
  fi
fi

# ----------------------------
# Model registry
# ----------------------------

declare -A MODEL_ARGS=(
  # Qwen2.5 Coder 7B GGUF local
  # Non-thinking mode: temp=0.7, top_p=0.8 (Qwen2.5 recommendation)
  [qwen2_5-coder]="
    -m $MODELS_DIR/qwen2.5-coder-7b-instruct-q4_k_m.gguf
    --chat-template chatml
    --ctx-size $LLAMA_CTX_SIZE_LARGE
    --batch-size 1024
    --ubatch-size 256
    --flash-attn on
    --cache-type-k q4_0
    --cache-type-v q4_0
    --temperature 0.7
    --top-p 0.8
    --min-p 0.01
    --n-gpu-layers auto
  "

  # Qwen3 8B GGUF local (standard transformer, full GPU support)
  # Non-thinking mode: temp=0.7, top_p=0.8 (Qwen3 recommendation)
  [qwen3]="
    -m $MODELS_DIR/Qwen3-8B-Q4_K_M.gguf
    --jinja
    --ctx-size $LLAMA_CTX_SIZE_LARGE
    --reasoning off
    --batch-size 1024
    --ubatch-size 256
    --flash-attn on
    --cache-type-k q4_0
    --cache-type-v q4_0
    --temperature 0.7
    --top-p 0.8
    --min-p 0.0
    --n-gpu-layers auto
  "

  # Qwen3.5 9B (Bartowski Q4_K_M) — non-thinking mode
  [qwen3_5]="
    -m $MODELS_DIR/Qwen_Qwen3.5-9B-Q4_K_M.gguf
    --jinja
    --ctx-size $LLAMA_CTX_SIZE_LARGE
    --batch-size 1024
    --ubatch-size 256
    --flash-attn on
    --cache-type-k q4_0
    --cache-type-v q4_0
    --temperature 0.7
    --top-p 0.8
    --top-k 20
    --min-p 0.0
    --presence-penalty 1.5
    --repeat-penalty 1.0
    --n-gpu-layers auto
  "

  # Qwen3.5 9B (Unsloth Dynamic Q4_K_XL) — thinking mode enabled by default
  # Precise coding: temp=0.6, top_p=0.95, top_k=20, min_p=0.0
  [qwen3_5_u9b]="
    -m $MODELS_DIR/Qwen3.5-9B-UD-Q4_K_XL.gguf
    --jinja
    --ctx-size $LLAMA_CTX_SIZE_QWEN3_5
    --batch-size 1024
    --ubatch-size 256
    --flash-attn on
    --cache-type-k q4_0
    --cache-type-v q4_0
    --temperature 0.6
    --top-p 0.95
    --top-k 20
    --min-p 0.0
    --presence-penalty 0.0
    --repeat-penalty 1.0
    --n-gpu-layers auto
  "

  # Qwen3.5 4B (Unsloth Dynamic Q4_K_XL) — thinking mode enabled by default
  [qwen3_5_u4b]="
    -m $MODELS_DIR/Qwen3.5-4B-UD-Q4_K_XL.gguf
    --jinja
    --ctx-size $LLAMA_CTX_SIZE_QWEN3_5
    --batch-size 1024
    --ubatch-size 512
    --flash-attn on
    --cache-type-k q4_0
    --cache-type-v q4_0
    --temperature 0.6
    --top-p 0.95
    --top-k 20
    --min-p 0.0
    --presence-penalty 0.0
    --repeat-penalty 1.0
    --n-gpu-layers auto
  "

  # Qwen3.5 2B (Unsloth Dynamic Q4_K_XL) — ultra fast, 5.5GB
  [qwen3_5_u2b]="
    -m $MODELS_DIR/Qwen3.5-2B-UD-Q4_K_XL.gguf
    --jinja
    --ctx-size $LLAMA_CTX_SIZE_QWEN3_5
    --batch-size 1024
    --ubatch-size 512
    --flash-attn on
    --cache-type-k q4_0
    --cache-type-v q4_0
    --temperature 0.6
    --top-p 0.95
    --top-k 20
    --min-p 0.0
    --presence-penalty 0.0
    --repeat-penalty 1.0
    --n-gpu-layers auto
  "

  # Qwen3.5 0.8B (Unsloth Dynamic Q4_K_XL) — minimal, 3.5GB
  [qwen3_5_u08b]="
    -m $MODELS_DIR/Qwen3.5-0.8B-UD-Q4_K_XL.gguf
    --jinja
    --ctx-size $LLAMA_CTX_SIZE_QWEN3_5
    --batch-size 1024
    --ubatch-size 512
    --flash-attn on
    --cache-type-k q4_0
    --cache-type-v q4_0
    --temperature 0.6
    --top-p 0.95
    --top-k 20
    --min-p 0.0
    --presence-penalty 0.0
    --repeat-penalty 1.0
    --n-gpu-layers auto
  "

  # Qwen3-Coder-Next 80B MoE (3B active params) - optimized for coding
  # Uses 4-bit quantization to fit in ~46GB RAM/VRAM
  # Recommended: temp=1.0, top_p=0.95, top_k=40, min_p=0.01
  [qwen3_coder_next]="
    -m $MODELS_DIR/Qwen3-Coder-Next-UD-Q4_K_XL.gguf
    --jinja
    --ctx-size $LLAMA_CTX_SIZE_LARGE
    --reasoning off
    --batch-size 1024
    --ubatch-size 256
    --flash-attn on
    --cache-type-k q4_0
    --cache-type-v q4_0
    --top-k 40
    --min-p 0.01
    --temperature 1.0
    --top-p 0.95
    --n-gpu-layers auto
  "

  # GLM-4.7-Flash 30B MoE (~3.6B active params) - Z.ai's reasoning model
  # 200K context window, excellent for coding and agentic workflows
  # Uses 4-bit quantization to fit in ~24GB RAM/VRAM
  # Recommended settings:
  #   General use-case: temp=1.0, top_p=0.95
  #   Tool-calling: temp=0.7, top_p=1.0
  #   Always disable repeat penalty (--repeat-penalty 1.0)
  [glm_4_7_flash]="
    -m $MODELS_DIR/GLM-4.7-Flash-UD-Q4_K_XL.gguf
    --jinja
    --ctx-size $LLAMA_CTX_SIZE_LARGE
    --reasoning off
    --batch-size 1024
    --ubatch-size 256
    --flash-attn on
    --cache-type-k q4_0
    --cache-type-v q4_0
    --temperature 1.0
    --top-p 0.95
    --repeat-penalty 1.0
    --n-gpu-layers auto
  "

  # Nemotron-3-Nano 30B MoE (3B active params, hybrid Mamba-2 + attention)
  # --cpu-moe keeps MoE expert weights in RAM; attention layers on GPU.
  # Supports thinking/reasoning mode via chat template flag.
  # Default: temp=1.0, top_p=1.0 (Nemotron 3 recommendation for general chat)
  [nemotron-nano]="
    -m $MODELS_DIR/nvidia_Nemotron-3-Nano-30B-A3B-Q4_K_M.gguf
    --jinja
    --ctx-size $LLAMA_CTX_SIZE_SMALL
    --reasoning off
    --batch-size 1024
    --ubatch-size 256
    --flash-attn on
    --cache-type-k q4_0
    --cache-type-v q4_0
    --cpu-moe
    --temperature 1.0
    --top-p 1.0
    --n-gpu-layers auto
  "

  # Gemma 4 E4B (IQ4_NL)
  # Tuned for larger context windows in coding agents (OpenCode/Continue/pi).
  # Trade-off: lower batch/ubatch for stability at higher ctx (slower throughput).
  # Parameters: Google-recommended temp=1.0, top_p=0.95, top_k=64
  # Thinking: use --reasoning flag to enable (default: disabled)
  [gemma4_e4b]="
    -m $MODELS_DIR/gemma-4-E4B-it-IQ4_NL.gguf
    --jinja
    --ctx-size $LLAMA_CTX_SIZE_LARGE
    --batch-size 512
    --ubatch-size 128
    --flash-attn on
    --cache-type-k q4_0
    --cache-type-v q4_0
    --temperature 1.0
    --top-p 0.95
    --top-k 64
    --min-p 0.0
    --n-gpu-layers auto
  "

  # Gemma 4 E4B multimodal preset.
  # Same larger-context profile as text-only preset, with reduced batch for stability.
  [gemma4_e4b_vision]="
    -m $MODELS_DIR/gemma-4-E4B-it-IQ4_NL.gguf
    --jinja
    --ctx-size $LLAMA_CTX_SIZE_LARGE
    --batch-size 512
    --ubatch-size 128
    --flash-attn on
    --cache-type-k q4_0
    --cache-type-v q4_0
    --temperature 0.7
    --top-p 0.9
    --min-p 0.0
    --n-gpu-layers auto
  "

  # Gemma 4 E4B (Q8_0) - 8-bit quantization for higher quality
  # Requires ~9-12GB total memory, may need partial offload on 8GB VRAM
  # Use smaller context or reduced GPU layers if you hit OOM
  # Parameters: Google-recommended temp=1.0, top_p=0.95, top_k=64
  # Thinking: use --reasoning flag to enable (default: disabled)
  [gemma4_e4b_q8]="
    -m $MODELS_DIR/gemma-4-E4B-it-Q8_0.gguf
    --jinja
    --ctx-size $LLAMA_CTX_SIZE_LARGE
    --batch-size 512
    --ubatch-size 128
    --flash-attn on
    --cache-type-k q4_0
    --cache-type-v q4_0
    --temperature 1.0
    --top-p 0.95
    --top-k 64
    --min-p 0.0
    --n-gpu-layers auto
  "

  # GPT-OSS 20B preset (downloads weights automatically)
  # MoE: 20.9B total / 3.6B active params. --cpu-moe keeps expert weights in
  # RAM while attention layers stay on GPU, optimal for 8GB VRAM.
  # Default: temp=0.7, top_p=0.9 (Llama 3-like settings for GPT-OSS)
  [gpt-oss]="
    --gpt-oss-20b-default
    --ctx-size $LLAMA_CTX_SIZE_SMALL
    --reasoning off
    --batch-size 1024
    --ubatch-size 256
    --flash-attn on
    --cache-type-k q4_0
    --cache-type-v q4_0
    --cpu-moe
    --temperature 0.7
    --top-p 0.9
    --min-p 0.0
    --n-gpu-layers auto
  "
)

declare -A MODEL_PORT=(
  [qwen2_5-coder]=8084
  [qwen3]=8084
  [qwen3_5]=8084
  [qwen3_5_u9b]=8084
  [qwen3_5_u4b]=8084
  [qwen3_5_u2b]=8084
  [qwen3_5_u08b]=8084
  [gpt-oss]=8084
  [gemma4_e4b]=8084
  [gemma4_e4b_vision]=8084
  [gemma4_e4b_q8]=8084
  [nemotron-nano]=8084
  [qwen3_coder_next]=8084
  [glm_4_7_flash]=8084
)

# HuggingFace source for auto-download: "owner/repo filename"
# Models without an entry (e.g. gpt-oss) are assumed to self-download
declare -A MODEL_HF=(
  [qwen2_5-coder]="Qwen/Qwen2.5-Coder-7B-Instruct-GGUF qwen2.5-coder-7b-instruct-q4_k_m.gguf"
  [qwen3]="Qwen/Qwen3-8B-GGUF Qwen3-8B-Q4_K_M.gguf"
  [qwen3_5]="bartowski/Qwen_Qwen3.5-9B-GGUF Qwen_Qwen3.5-9B-Q4_K_M.gguf"
  [qwen3_5_u9b]="unsloth/Qwen3.5-9B-GGUF Qwen3.5-9B-UD-Q4_K_XL.gguf"
  [qwen3_5_u4b]="unsloth/Qwen3.5-4B-GGUF Qwen3.5-4B-UD-Q4_K_XL.gguf"
  [qwen3_5_u2b]="unsloth/Qwen3.5-2B-GGUF Qwen3.5-2B-UD-Q4_K_XL.gguf"
  [qwen3_5_u08b]="unsloth/Qwen3.5-0.8B-GGUF Qwen3.5-0.8B-UD-Q4_K_XL.gguf"
  [nemotron-nano]="bartowski/nvidia_Nemotron-3-Nano-30B-A3B-GGUF nvidia_Nemotron-3-Nano-30B-A3B-Q4_K_M.gguf"
  [qwen3_coder_next]="unsloth/Qwen3-Coder-Next-GGUF Qwen3-Coder-Next-UD-Q4_K_XL.gguf"
  [glm_4_7_flash]="unsloth/GLM-4.7-Flash-GGUF GLM-4.7-Flash-UD-Q4_K_XL.gguf"
  [gemma4_e4b]="unsloth/gemma-4-E4B-it-GGUF gemma-4-E4B-it-IQ4_NL.gguf"
  [gemma4_e4b_vision]="unsloth/gemma-4-E4B-it-GGUF gemma-4-E4B-it-IQ4_NL.gguf"
  [gemma4_e4b_q8]="unsloth/gemma-4-E4B-it-GGUF gemma-4-E4B-it-Q8_0.gguf"
)

# Models that support --chat-template-kwargs for thinking toggle
REASONING_MODELS=(qwen3 qwen3_5 qwen3_5_u9b qwen3_5_u4b qwen3_5_u2b qwen3_5_u08b gpt-oss nemotron-nano glm_4_7_flash gemma4_e4b gemma4_e4b_vision gemma4_e4b_q8)

# Local path for each model file
declare -A MODEL_PATH=(
  [qwen2_5-coder]="$MODELS_DIR/qwen2.5-coder-7b-instruct-q4_k_m.gguf"
  [qwen3]="$MODELS_DIR/Qwen3-8B-Q4_K_M.gguf"
  [qwen3_5]="$MODELS_DIR/Qwen_Qwen3.5-9B-Q4_K_M.gguf"
  [qwen3_5_u9b]="$MODELS_DIR/Qwen3.5-9B-UD-Q4_K_XL.gguf"
  [qwen3_5_u4b]="$MODELS_DIR/Qwen3.5-4B-UD-Q4_K_XL.gguf"
  [qwen3_5_u2b]="$MODELS_DIR/Qwen3.5-2B-UD-Q4_K_XL.gguf"
  [qwen3_5_u08b]="$MODELS_DIR/Qwen3.5-0.8B-UD-Q4_K_XL.gguf"
  [nemotron-nano]="$MODELS_DIR/nvidia_Nemotron-3-Nano-30B-A3B-Q4_K_M.gguf"
  [qwen3_coder_next]="$MODELS_DIR/Qwen3-Coder-Next-UD-Q4_K_XL.gguf"
  [glm_4_7_flash]="$MODELS_DIR/GLM-4.7-Flash-UD-Q4_K_XL.gguf"
  [gemma4_e4b]="$MODELS_DIR/gemma-4-E4B-it-IQ4_NL.gguf"
  [gemma4_e4b_vision]="$MODELS_DIR/gemma-4-E4B-it-IQ4_NL.gguf"
  [gemma4_e4b_q8]="$MODELS_DIR/gemma-4-E4B-it-Q8_0.gguf"
)

# Draft models for speculative decoding (must share tokenizer with the target)
# Qwen3.5 0.8B serves as draft for all Small models
declare -A MODEL_DRAFT_HF=(
  [qwen2_5-coder]="Qwen/Qwen2.5-Coder-0.5B-Instruct-GGUF qwen2.5-coder-0.5b-instruct-q4_k_m.gguf"
  [qwen3]="Qwen/Qwen3-0.6B-GGUF Qwen3-0.6B-Q8_0.gguf"
  [qwen3_5]="unsloth/Qwen3.5-0.8B-GGUF Qwen3.5-0.8B-UD-Q4_K_XL.gguf"
  [qwen3_5_u9b]="unsloth/Qwen3.5-0.8B-GGUF Qwen3.5-0.8B-UD-Q4_K_XL.gguf"
  [qwen3_5_u4b]="unsloth/Qwen3.5-0.8B-GGUF Qwen3.5-0.8B-UD-Q4_K_XL.gguf"
  [qwen3_5_u2b]="unsloth/Qwen3.5-0.8B-GGUF Qwen3.5-0.8B-UD-Q4_K_XL.gguf"
  [qwen3_5_u08b]="unsloth/Qwen3.5-0.8B-GGUF Qwen3.5-0.8B-UD-Q4_K_XL.gguf"
)

declare -A MODEL_DRAFT_PATH=(
  [qwen2_5-coder]="$MODELS_DIR/qwen2.5-coder-0.5b-instruct-q4_k_m.gguf"
  [qwen3]="$MODELS_DIR/Qwen3-0.6B-Q8_0.gguf"
  [qwen3_5]="$MODELS_DIR/Qwen3.5-0.8B-UD-Q4_K_XL.gguf"
  [qwen3_5_u9b]="$MODELS_DIR/Qwen3.5-0.8B-UD-Q4_K_XL.gguf"
  [qwen3_5_u4b]="$MODELS_DIR/Qwen3.5-0.8B-UD-Q4_K_XL.gguf"
  [qwen3_5_u2b]="$MODELS_DIR/Qwen3.5-0.8B-UD-Q4_K_XL.gguf"
  [qwen3_5_u08b]="$MODELS_DIR/Qwen3.5-0.8B-UD-Q4_K_XL.gguf"
)

# Vision projector files for multimodal models
# Format: "owner/repo filename" on HuggingFace
declare -A MODEL_MM_PROJ_HF=(
  [gemma4_e4b_vision]="unsloth/gemma-4-E4B-it-GGUF mmproj-F16.gguf"
  [qwen3_5_u9b]="unsloth/Qwen3.5-9B-GGUF mmproj-F16.gguf"
  [qwen3_5_u4b]="unsloth/Qwen3.5-4B-GGUF mmproj-F16.gguf"
  [qwen3_5_u2b]="unsloth/Qwen3.5-2B-GGUF mmproj-F16.gguf"
  [qwen3_5_u08b]="unsloth/Qwen3.5-0.8B-GGUF mmproj-F16.gguf"
)

declare -A MODEL_MM_PROJ_PATH=(
  [gemma4_e4b_vision]="$MODELS_DIR/mmproj-F16.gguf"
  [qwen3_5_u9b]="$MODELS_DIR/Qwen3.5-9B-mmproj-F16.gguf"
  [qwen3_5_u4b]="$MODELS_DIR/Qwen3.5-4B-mmproj-F16.gguf"
  [qwen3_5_u2b]="$MODELS_DIR/Qwen3.5-2B-mmproj-F16.gguf"
  [qwen3_5_u08b]="$MODELS_DIR/Qwen3.5-0.8B-mmproj-F16.gguf"
)

# =============================================================================
# Model management
# =============================================================================

download_hf() {
  local repo="$1" file="$2" dest="$3"
  mkdir -p "$(dirname "$dest")"
  hf download "$repo" "$file" --local-dir "$(dirname "$dest")"
}

ensure_model() {
  local model="$1"
  [[ -z "${MODEL_PATH[$model]+x}" ]] && return 0

  local model_path="${MODEL_PATH[$model]}"
  [[ -f "$model_path" ]] && return 0

  if [[ -z "${MODEL_HF[$model]+x}" ]]; then
    echo "Error: model file not found: $model_path"
    exit 1
  fi

  local repo file
  read -r repo file <<< "${MODEL_HF[$model]}"
  
  # Check if file looks like a shorthand quant (e.g., "Q8_0") or full filename
  if [[ "$file" =~ ^[A-Z0-9_]+$ ]]; then
    # It's a shorthand quant - llama-server -hf can handle this directly
    echo "Model not found. Will download using -hf $repo:$file"
    HF_DOWNLOAD_ARGS+=("-hf" "$repo:$file")
  else
    # It's a full filename - use hf download directly (works better with Xet)
    echo "Model not found. Downloading $file from $repo..."
    download_hf "$repo" "$file" "$model_path"
  fi
}

ensure_draft_model() {
  local model="$1"
  [[ -z "${MODEL_DRAFT_PATH[$model]+x}" ]] && return 0

  local draft_path="${MODEL_DRAFT_PATH[$model]}"
  [[ -f "$draft_path" ]] && return 0

  if [[ -z "${MODEL_DRAFT_HF[$model]+x}" ]]; then
    echo "Error: draft model not found: $draft_path"
    exit 1
  fi

  local repo file
  read -r repo file <<< "${MODEL_DRAFT_HF[$model]}"
  echo "Draft model not found. Downloading $file from $repo..."
  download_hf "$repo" "$file" "$draft_path"
}

ensure_mmproj() {
  local model="$1"
  [[ -z "${MODEL_MM_PROJ_PATH[$model]+x}" ]] && return 0

  local mmproj_path="${MODEL_MM_PROJ_PATH[$model]}"
  [[ -f "$mmproj_path" ]] && return 0

  if [[ -z "${MODEL_MM_PROJ_HF[$model]+x}" ]]; then
    echo "Error: mmproj file not found: $mmproj_path"
    echo "Hint: set MODEL_MM_PROJ_HF for $model or place the file manually"
    exit 1
  fi

  local repo file
  read -r repo file <<< "${MODEL_MM_PROJ_HF[$model]}"
  echo "Vision projector not found. Downloading $file from $repo..."
  download_hf "$repo" "$file" "$mmproj_path"
}

# =============================================================================
# Benchmark
# =============================================================================

_bench_http() {
  local url="$1" payload="$2"
  if command -v curl &>/dev/null; then
    curl -sf --max-time 300 -X POST "$url" \
      -H "Content-Type: application/json" -d "$payload"
  else
    wget -qO- --timeout=300 --post-data="$payload" \
      --header="Content-Type: application/json" "$url"
  fi
}

_bench_wait() {
  local base_url="$1"
  echo -n "  Waiting for server"
  for _ in $(seq 1 90); do
    local r
    if command -v curl &>/dev/null; then
      r=$(curl -sf --max-time 2 "$base_url/health" 2>/dev/null) || true
    else
      r=$(wget -qO- --timeout=2 "$base_url/health" 2>/dev/null) || true
    fi
    if echo "$r" | grep -q '"status":"ok"'; then echo " ok"; return 0; fi
    echo -n "."; sleep 2
  done
  echo " timeout"; return 1
}

_bench_run() {
  local base_url="$1" n="$2" n_predict="$3"
  local prompt="Explain in detail how attention mechanisms work in transformer neural networks, covering self-attention, multi-head attention, positional encodings, and the training process."
  local payload="{\"prompt\":\"$prompt\",\"n_predict\":$n_predict,\"temperature\":0}"
  local tmp
  tmp=$(mktemp -d)

  # warmup
  _bench_http "$base_url/completion" "$payload" > /dev/null 2>&1 || true

  for i in $(seq 1 "$n"); do
    _bench_http "$base_url/completion" "$payload" > "$tmp/r$i.json" 2>/dev/null || true
  done

  python3 - "$tmp" <<'PYEOF'
import json, sys, os, glob
total_tokens = total_ms = count = 0
for f in glob.glob(os.path.join(sys.argv[1], '*.json')):
    try:
        d = json.load(open(f))
        t = d.get('timings', {})
        total_tokens += t.get('predicted_n', 0)
        total_ms += t.get('predicted_ms', 0.0)
        count += 1
    except: pass
if total_ms > 0:
    tps = total_tokens / (total_ms / 1000)
    print(f"{tps:.1f} t/s  ({total_tokens} tokens, {count} req)")
else:
    print("N/A")
PYEOF
  rm -rf "$tmp"
}

benchmark_model() {
  local model="$1"
  local port=19999
  local base_url="http://127.0.0.1:$port"
  local n="${BENCH_REQUESTS:-10}"
  local n_predict="${BENCH_N_PREDICT:-256}"

  if [[ -z "${MODEL_ARGS[$model]+x}" ]]; then
    echo "Invalid model: $model"; usage; exit 1
  fi

  if ! command -v python3 &>/dev/null; then
    echo "Error: python3 is required for benchmark mode"
    exit 1
  fi

  ensure_model "$model"
  ensure_mmproj "$model"

  # Always disable reasoning for consistent benchmark results
  # Omit --reasoning-budget entirely to truly disable reasoning mode
  local reasoning_args=()

  local has_draft=0
  [[ -n "${MODEL_DRAFT_PATH[$model]+x}" ]] && has_draft=1
  local total_runs=$(( 1 + has_draft ))

  echo ""
  echo "=== Benchmark: $model ==="
  echo "    $n requests x $n_predict tokens"

  # --- baseline ---
  echo ""
  echo "[ 1/$total_runs ] Baseline (no draft)"
  local server_pid
  # shellcheck disable=SC2086
  "$LLAMA_SERVER" \
    --threads "$LLAMA_THREADS" --threads-batch "$LLAMA_THREADS_BATCH" \
    --threads-http "$LLAMA_THREADS_HTTP" --parallel 1 \
    --log-disable \
    ${=MODEL_ARGS[$model]} \
    "${mmproj_args[@]}" \
    --host 127.0.0.1 --port "$port" \
"${reasoning_args[@]}" > /dev/null 2>&1 &
  server_pid=$!

  if ! _bench_wait "$base_url"; then
    kill "$server_pid" 2>/dev/null; return 1
  fi

  local baseline
  baseline=$(_bench_run "$base_url" "$n" "$n_predict")
  echo "  Result: $baseline"
  kill "$server_pid" 2>/dev/null; wait "$server_pid" 2>/dev/null

  # --- speculative decoding ---
  if [[ $has_draft -eq 1 ]]; then
    ensure_draft_model "$model"
    local draft_path="${MODEL_DRAFT_PATH[$model]}"

    echo ""
    echo "[ 2/2 ] With draft model ($(basename "$draft_path"))"
    # shellcheck disable=SC2086
    "$LLAMA_SERVER" \
      --host 127.0.0.1 --port "$port" \
      --threads "$LLAMA_THREADS" --threads-batch "$LLAMA_THREADS_BATCH" \
      --threads-http "$LLAMA_THREADS_HTTP" --parallel 1 \
      --log-disable \
      --model-draft "$draft_path" \
      ${=MODEL_ARGS[$model]} > /dev/null 2>&1 &
  server_pid=$!

    if ! _bench_wait "$base_url"; then
      kill "$server_pid" 2>/dev/null; return 1
    fi

    local draft_result
    draft_result=$(_bench_run "$base_url" "$n" "$n_predict")
    echo "  Result: $draft_result"
    kill "$server_pid" 2>/dev/null; wait "$server_pid" 2>/dev/null

    python3 -c "
b = float('$baseline'.split()[0]) if '$baseline' != 'N/A' else 0
d = float('$draft_result'.split()[0]) if '$draft_result' != 'N/A' else 0
if b > 0 and d > 0:
    pct = (d - b) / b * 100
    sign = '+' if pct >= 0 else ''
    print(f'  Speedup:  {sign}{pct:.1f}%')
" 2>/dev/null
  fi

  echo ""
  echo "==================================="
}

# =============================================================================
# Router (multi-model server)
# =============================================================================

router_usage() {
  cat <<EOF
Usage:
  llm-server router [flags]

Flags:
  --port N            Port (default: 8084)
  --small MODEL       Small model for autocompletion (default: qwen3_5_u08b)
  --big MODELS        Comma-separated big models (default: qwen3_5_u9b,gemma4_e4b,gemma4_e4b_q8)
  --reasoning         Enable reasoning for big models (Qwen3 family)
  --no-reasoning      Disable reasoning (default)
  --no-autoload       Disable auto-load on request
  --models-max N      Max models loaded simultaneously (default: 4)
  --host HOST         Bind address (default: 0.0.0.0)
  --                  Everything after this is passed to llama-server

Available models for router:
  Small (CPU):  qwen3_5_u08b, qwen3_5_u2b
  Big (GPU):    qwen3_5_u9b, qwen3_5_u4b, qwen3_5_u2b, gemma4_e4b, gemma4_e4b_q8

Examples:
  llm-server router
  llm-server router --small qwen3_5_u2b
  llm-server router --big qwen3_5_u9b,gemma4_e4b
  llm-server router --big qwen3_5_u9b,gemma4_e4b_q8
  llm-server router --big gemma4_e4b_q8
  llm-server router --reasoning
  llm-server router --port 9000
EOF
}

run_router() {
  local host="$SERVER_HOST"
  local port="$SERVER_PORT"
  local small_model="$ROUTER_SMALL_MODEL"
  local big_models="$ROUTER_BIG_MODELS"
  local models_max="$ROUTER_MODELS_MAX"
  local reasoning=0
  local autoload=true
  local passthru=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --host)
      [[ $# -lt 2 ]] && { echo "Error: --host requires a value"; exit 1; }
      host="$2"; shift 2
      ;;
    --port)
      [[ $# -lt 2 ]] && { echo "Error: --port requires a value"; exit 1; }
      port="$2"; shift 2
      ;;
    --small)
      [[ $# -lt 2 ]] && { echo "Error: --small requires a value"; exit 1; }
      small_model="$2"; shift 2
      ;;
    --big)
      [[ $# -lt 2 ]] && { echo "Error: --big requires a value"; exit 1; }
      big_models="$2"; shift 2
      ;;
    --reasoning)    reasoning=1;  shift   ;;
    --no-reasoning) reasoning=0;  shift   ;;
    --no-autoload)  autoload=false; shift ;;
    --models-max)
      [[ $# -lt 2 ]] && { echo "Error: --models-max requires a value"; exit 1; }
      models_max="$2"; shift 2
      ;;
    --)             shift; passthru+=("$@"); break ;;
    -h|--help)      router_usage; exit 0 ;;
    *)              echo "Unknown argument: $1"; router_usage; exit 1 ;;
    esac
  done

  local valid_small=(qwen3_5_u08b qwen3_5_u2b)
  local valid_big=(qwen3_5_u9b qwen3_5_u4b qwen3_5_u2b gemma4_e4b gemma4_e4b_q8)

  local is_valid=0
  for m in "${valid_small[@]}"; do
    [[ "$small_model" == "$m" ]] && is_valid=1
  done
  if [[ $is_valid -eq 0 ]]; then
    echo "Error: invalid small model '$small_model'"
    echo "Valid options: ${valid_small[*]}"
    exit 1
  fi

  IFS=',' read -A big_arr <<< "$big_models"
  for bm in "${big_arr[@]}"; do
    is_valid=0
    for m in "${valid_big[@]}"; do
      [[ "$bm" == "$m" ]] && is_valid=1
    done
    if [[ $is_valid -eq 0 ]]; then
      echo "Error: invalid big model '$bm'"
      echo "Valid options: ${valid_big[*]}"
      exit 1
    fi
  done

  echo "Starting router with:"
  echo "  Small model (CPU): $small_model"
  echo "  Big models (GPU): $big_models"
  echo "  Port: $port"
  echo "  Reasoning: $([ $reasoning -eq 1 ] && echo 'enabled' || echo 'disabled')"
  echo ""

  ensure_model "$small_model"
  for bm in "${big_arr[@]}"; do
    ensure_model "$bm"
  done

  for bm in "${big_arr[@]}"; do
    local model_path="${MODEL_PATH[$bm]}"
    if [[ ! -f "$model_path" && -n "${MODEL_HF[$bm]+x}" ]]; then
      local repo file
      read -r repo file <<< "${MODEL_HF[$bm]}"
      echo "Downloading $bm from HuggingFace..."
      download_hf "$repo" "$file" "$model_path"
    fi
  done

  local small_path="${MODEL_PATH[$small_model]}"
  if [[ ! -f "$small_path" && -n "${MODEL_HF[$small_model]+x}" ]]; then
    local repo file
    read -r repo file <<< "${MODEL_HF[$small_model]}"
    echo "Downloading $small_model from HuggingFace..."
    download_hf "$repo" "$file" "$small_path"
  fi

  local tmpfile
  tmpfile=$(mktemp)

  cat > "$tmpfile" << EOF
version = 1

[*]
ctx-size = $LLAMA_CTX_SIZE_LARGE
batch-size = 512
ubatch-size = 128
flash-attn = on
cache-type-k = q4_0
cache-type-v = q4_0
parallel = 1

[$small_model]
model = ${MODEL_PATH[$small_model]}
n-gpu-layers = 0
temperature = 0.6
top-p = 0.95
load-on-startup = true
chat-template-kwargs = {"enable_thinking":false}

EOF

  for bm in "${big_arr[@]}"; do
    local n_gpu="auto"
    local temp="0.6"
    local top_p="0.95"
    local reasoning_arg=""

    if [[ "$bm" == gemma4* ]]; then
      temp="1.0"
      top_p="0.95"
      # Gemma 4 uses chat-template-kwargs for thinking control
      if [[ $reasoning -eq 1 ]]; then
        reasoning_arg="chat-template-kwargs = {\"enable_thinking\":true}"
      else
        reasoning_arg="chat-template-kwargs = {\"enable_thinking\":false}"
      fi
    fi

    if [[ $reasoning -eq 1 ]]; then
      if [[ "$bm" == qwen3_5* ]]; then
        reasoning_arg="chat-template-kwargs = {\"enable_thinking\":true}"
      fi
    else
      if [[ "$bm" == qwen3_5* ]]; then
        reasoning_arg="chat-template-kwargs = {\"enable_thinking\":false}"
      fi
    fi

    cat >> "$tmpfile" << EOF
[$bm]
model = ${MODEL_PATH[$bm]}
n-gpu-layers = $n_gpu
temperature = $temp
top-p = $top_p
$reasoning_arg

EOF
  done

  echo "Preset file created: $tmpfile"

  local autoload_flag="--models-autoload"
  $autoload || autoload_flag="--no-models-autoload"

  # shellcheck disable=SC2086
  exec "$LLAMA_SERVER" \
    --threads "$LLAMA_THREADS" \
    --threads-batch "$LLAMA_THREADS_BATCH" \
    --threads-http "$LLAMA_THREADS_HTTP" \
    --parallel "$LLAMA_PARALLEL" \
    --host "$host" \
    --port "$port" \
    --models-preset "$tmpfile" \
    --models-max "$models_max" \
    $autoload_flag \
    "${passthru[@]}"
}

# =============================================================================
# Setup
# =============================================================================

setup_llama() {
  local os
  os=$(uname -s)
  local ncpu
  ncpu=$(nproc 2>/dev/null || sysctl -n hw.logicalcpu)

  # --- package check ---
  local missing=()
  if [[ "$os" == "Darwin" ]]; then
    if ! command -v brew &>/dev/null; then
      echo "Error: Homebrew not found. Install it from https://brew.sh"
      exit 1
    fi
    for pkg in git cmake ninja; do
      brew list "$pkg" &>/dev/null || missing+=("$pkg")
    done
    command -v gcc &>/dev/null || missing+=(gcc)
    if [[ ${#missing[@]} -gt 0 ]]; then
      echo "Required packages not found: ${missing[*]}"
      brew install "${missing[@]}"
    fi
  else
    for pkg in git cmake ninja cuda; do
      pacman -Q "$pkg" &>/dev/null || missing+=("$pkg")
    done
    command -v gcc &>/dev/null || missing+=(base-devel)
    if [[ ${#missing[@]} -gt 0 ]]; then
      echo "Required packages not found: ${missing[*]}"
      sudo pacman -S --needed "${missing[@]}"
    fi
  fi

  # --- GPU info ---
  if [[ "$os" == "Darwin" ]]; then
    echo "Apple Silicon detected — Metal GPU acceleration will be used."
    system_profiler SPDisplaysDataType 2>/dev/null | grep -E "Chipset Model|VRAM" || true
  elif command -v nvidia-smi &>/dev/null && nvidia-smi &>/dev/null; then
    echo "NVIDIA GPU detected:"
    nvidia-smi --query-gpu=name,driver_version,memory.total --format=csv,noheader
  else
    echo "Warning: nvidia-smi not found or failed."
    echo "  The NVIDIA driver may not be installed or loaded."
    echo "  Build will continue without CUDA/GPU support."
  fi

  # --- clone / update ---
  if [[ ! -d "$LLAMA_DIR" ]]; then
    echo "Cloning llama.cpp into $LLAMA_DIR..."
    git clone https://github.com/ggml-org/llama.cpp "$LLAMA_DIR"
  else
    echo "Updating llama.cpp..."
    git -C "$LLAMA_DIR" pull
  fi

  # --- build flags ---
  local gpu_flags=()
  if [[ "$os" == "Darwin" ]]; then
    echo "Building for Apple Silicon (Metal)..."
    gpu_flags=(-DGGML_METAL=ON -DCMAKE_OSX_ARCHITECTURES=arm64)
  else
    # Locate CUDA toolkit (Arch installs to /opt/cuda, not in PATH by default)
    local cuda_root=""
    if command -v nvcc &>/dev/null; then
      cuda_root="$(dirname "$(dirname "$(command -v nvcc)")")"
    else
      for candidate in /opt/cuda /usr/local/cuda /usr/lib/cuda; do
        if [[ -x "$candidate/bin/nvcc" ]]; then
          cuda_root="$candidate"; break
        fi
      done
    fi

    if [[ -n "$cuda_root" ]]; then
      echo "CUDA toolkit found at: $cuda_root"
      echo "Building for Ryzen 7 5700X + RTX 3070 Ti (SM 8.6)..."
      gpu_flags=(
        -DGGML_CUDA=ON
        -DCUDAToolkit_ROOT="$cuda_root"
        -DCMAKE_CUDA_COMPILER="$cuda_root/bin/nvcc"
        -DCMAKE_CUDA_ARCHITECTURES=86
        -DGGML_CUDA_FA_ALL_QUANTS=ON
      )
    else
      echo "Warning: CUDA toolkit (nvcc) not found. Building without GPU support."
      echo "  Install the 'cuda' package and try again: sudo pacman -S cuda"
    fi
  fi

  cmake -S "$LLAMA_DIR" -B "$LLAMA_DIR/build" \
    -DCMAKE_BUILD_TYPE=Release \
    "${gpu_flags[@]}" \
    -DGGML_NATIVE=ON \
    -GNinja

  cmake --build "$LLAMA_DIR/build" --config Release -j"$ncpu"
  echo "Done: $LLAMA_DIR/build/bin/llama-server"

  # --- create config file ---
  if [[ ! -f "$CONFIG_FILE" ]]; then
    echo ""
    echo "Creating default configuration file..."
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" << 'EOF'
# llm-server configuration file
# This file was created automatically during setup
# Environment variables override these settings
# This is a shell-compatible config file - use KEY=VALUE format

# ============================================================================
# Paths
# ============================================================================

# Path to llama.cpp installation directory
LLAMA_CPP=$HOME/applications/llama.cpp

# Directory where models are stored and downloaded
MODELS=$HOME/models

# ============================================================================
# Server Settings
# ============================================================================

# Default bind address
HOST=0.0.0.0

# Default port for llama-server
PORT=8084

# ============================================================================
# Performance Settings
# ============================================================================

# Number of CPU threads for inference
THREADS=8

# Number of threads for batch processing
THREADS_BATCH=12

# Number of HTTP handler threads
THREADS_HTTP=4

# Number of parallel inference slots
PARALLEL=2

# Qwen3.5 Unsloth presets context window (for coding agents / tools)
CTX_SIZE_QWEN3_5=262144

# ============================================================================
# Benchmark Settings
# ============================================================================

# Number of requests for benchmarking
BENCH_REQUESTS_CONF=10

# Number of tokens to predict per request
BENCH_N_PREDICT_CONF=256

# ============================================================================
# Security
# ============================================================================

# API key required to access the server (leave empty to disable)
API_KEY=
EOF
    echo "Created: $CONFIG_FILE"
    echo "Edit this file to customize default settings."
  fi
}

# =============================================================================
# Profile / diagnostics
# =============================================================================

show_profile() {
  local model="${1:-}"

  if [[ -n "$model" ]] && [[ -z "${MODEL_PORT[$model]+x}" ]]; then
    echo "Invalid model for profile: $model"
    echo "Tip: run 'llm-server --help' for valid model names"
    exit 1
  fi

  echo "llm-server profile"
  echo "  Hostname:           $HOSTNAME_SHORT"
  if [[ "$HOSTNAME_SHORT" == "donan" ]]; then
    echo "  Preset:             donan (Ryzen 7 5700X + RTX 3070 Ti)"
  else
    echo "  Preset:             generic"
  fi
  echo ""
  echo "Paths"
  echo "  LLAMA_DIR:          $LLAMA_DIR"
  echo "  MODELS_DIR:         $MODELS_DIR"
  echo "  CONFIG_FILE:        $CONFIG_FILE"
  echo ""
  echo "Server defaults"
  echo "  HOST:               $SERVER_HOST"
  echo "  PORT (base):        $SERVER_PORT"
  echo ""
  echo "Runtime defaults"
  echo "  LLAMA_THREADS:      $LLAMA_THREADS"
  echo "  LLAMA_THREADS_BATCH: $LLAMA_THREADS_BATCH"
  echo "  LLAMA_THREADS_HTTP: $LLAMA_THREADS_HTTP"
  echo "  LLAMA_PARALLEL:     $LLAMA_PARALLEL"
  echo "  CTX_SIZE_LARGE:     $LLAMA_CTX_SIZE_LARGE"
  echo "  CTX_SIZE_SMALL:     $LLAMA_CTX_SIZE_SMALL"
  echo "  CTX_SIZE_QWEN3_5:   $LLAMA_CTX_SIZE_QWEN3_5"
  echo ""

  if [[ -n "$model" ]]; then
    local model_port="${MODEL_PORT[$model]}"
    local effective_port="$SERVER_PORT"
    [[ -z "$effective_port" ]] && effective_port="$model_port"
    echo "Model-specific"
    echo "  MODEL:              $model"
    echo "  MODEL_PORT:         $model_port"
    echo "  EFFECTIVE_PORT:     $effective_port"
  fi
}

# =============================================================================
# Usage
# =============================================================================

usage() {
  cat <<EOF
Usage:
  llm-server setup
  llm-server profile [model]
  llm-server benchmark <model>
  llm-server router [flags]
  llm-server <model> [flags] [-- extra llama-server args...]

Models: qwen2_5-coder | qwen3 | qwen3_5 | qwen3_5_u9b | qwen3_5_u4b | qwen3_5_u2b | qwen3_5_u08b | gpt-oss | nemotron-nano | qwen3_coder_next | glm_4_7_flash | gemma4_e4b | gemma4_e4b_q8 | gemma4_e4b_vision

Commands:
  setup               clone/update llama.cpp and build with CUDA (RTX 3070 Ti + 5700X)
  profile [model]     print active runtime profile/settings (optionally for model)
  benchmark <model>   measure throughput with and without speculative decoding
  router [flags]      start multi-model router server (small CPU + big GPU)

Router Flags:
  --port N            Port (default: 8084)
  --small MODEL      Small model for autocompletion (default: qwen3_5_u08b)
  --big MODELS       Comma-separated big models (default: qwen3_5_u9b,gemma4_e4b,gemma4_e4b_q8)
  --reasoning        Enable reasoning for big models (Qwen3 family)
  --no-reasoning     Disable reasoning (default)
  --no-autoload      Disable auto-load on request
  --models-max N     Max models loaded simultaneously (default: 4)

Valid router models:
  Small (CPU):  qwen3_5_u08b, qwen3_5_u2b
  Big (GPU):    qwen3_5_u9b, qwen3_5_u4b, qwen3_5_u2b, gemma4_e4b, gemma4_e4b_q8

Flags:
  --reasoning         enable reasoning/thinking mode (Qwen3 family only)
  --no-reasoning      disable reasoning/thinking mode (default)
  --draft             enable speculative decoding with the model's draft model
  --no-draft          disable speculative decoding (default)
  --vision            enable vision/multimodal support
  --no-vision        disable vision support (default)
  --host HOST         bind address (default: 0.0.0.0)
  --port N            override default port (default: 8084)
  --api-key KEY       require this key on all requests

Configuration:
  Config file: ~/.config/llm-server/config.conf
  Precedence: Environment variables > Config file > Hardcoded defaults
  Run 'llm-server setup' to create the default config file.

Env overrides (5700X defaults):
  LLAMA_THREADS=8       LLAMA_THREADS_BATCH=12
  LLAMA_THREADS_HTTP=4  LLAMA_PARALLEL=2
  LLAMA_CTX_SIZE_QWEN3_5=262144
  LLAMA_DIR=$HOME/applications/llama.cpp
  BENCH_REQUESTS=10     BENCH_N_PREDICT=256

Examples:
  llm-server setup
  llm-server profile
  llm-server profile qwen3
  llm-server benchmark qwen3
  llm-server router
  llm-server router --small qwen3_5_u2b
  llm-server router --big qwen3_5_u9b,gemma4_e4b
  llm-server router --big qwen3_5_u9b,gemma4_e4b_q8
  llm-server router --big gemma4_e4b_q8
  llm-server router --reasoning
  llm-server router --port 9000
  llm-server qwen3
  llm-server qwen3 --draft
  llm-server qwen3 --reasoning
  llm-server qwen3_5_u9b
  llm-server qwen3_5_u4b
  llm-server qwen3_5_u2b
  llm-server qwen3_5_u08b
  llm-server qwen2_5-coder --port 9000
  llm-server qwen3_coder_next
  llm-server gemma4_e4b
  llm-server gemma4_e4b_q8
  llm-server gemma4_e4b_vision
  llm-server glm_4_7_flash --reasoning
  llm-server gemma4_e4b_vision --vision
  llm-server gemma4_e4b_q8 --reasoning
  llm-server qwen3 -- --log-verbosity 4
EOF
}

# =============================================================================
# Main
# =============================================================================

if [[ $# -lt 1 ]]; then
  usage; exit 1
fi

if [[ "$1" == "setup" ]]; then
  setup_llama; exit 0
fi

if [[ "$1" == "profile" ]]; then
  show_profile "${2:-}"
  exit 0
fi

if [[ "$1" == "benchmark" ]]; then
  [[ $# -lt 2 ]] && { echo "Usage: llm-server benchmark <model>"; exit 1; }
  benchmark_model "$2"; exit 0
fi

if [[ "$1" == "router" ]]; then
  run_router "${@:2}"; exit $?
fi

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
  usage; exit 0
fi

MODEL="$1"
shift
if [[ -z "${MODEL_ARGS[$MODEL]+x}" ]]; then
  echo "Invalid model: $MODEL"; usage; exit 1
fi

HOST="$SERVER_HOST"
PORT="${SERVER_PORT:-${MODEL_PORT[$MODEL]}}"
REASONING=0
DRAFT=0
VISION=0
HF_DOWNLOAD_ARGS=()

# Parse script args; everything after "--" is passed directly to llama-server
PASSTHRU=()
while [[ $# -gt 0 ]]; do
  case "$1" in
  --host)
    [[ $# -lt 2 ]] && { echo "Error: --host requires a value"; exit 1; }
    HOST="$2"
    shift 2
    ;;
  --port)
    [[ $# -lt 2 ]] && { echo "Error: --port requires a value"; exit 1; }
    PORT="$2"
    shift 2
    ;;
  --api-key)
    [[ $# -lt 2 ]] && { echo "Error: --api-key requires a value"; exit 1; }
    LLAMA_API_KEY="$2"
    shift 2
    ;;
  --reasoning)    REASONING=1;  shift   ;;
  --no-reasoning) REASONING=0;  shift   ;;
  --draft)        DRAFT=1;      shift   ;;
  --no-draft)     DRAFT=0;      shift   ;;
  --vision)      VISION=1;      shift   ;;
  --no-vision)   VISION=0;      shift   ;;
  --)             shift; PASSTHRU+=("$@"); break ;;
  -h|--help)      usage; exit 0 ;;
  *)              echo "Unknown argument: $1"; usage; exit 1 ;;
  esac
done

ensure_model "$MODEL"
if [[ $VISION -eq 1 ]]; then
  ensure_mmproj "$MODEL"
fi

# Reasoning/thinking mode via --chat-template-kwargs (Qwen3.5, Gemma 4) or --reasoning-budget (Qwen3)
# Qwen3.5 / Gemma 4: enabled with '{"enable_thinking":true}', disabled with '{"enable_thinking":false}'
# Qwen3: enabled with --reasoning-budget -1
REASONING_ARGS=()
if printf '%s\n' "${REASONING_MODELS[@]}" | grep -qx "$MODEL"; then
  if [[ "$MODEL" == qwen3_5* || "$MODEL" == gemma4* ]]; then
    # Qwen3.5 and Gemma 4 use chat-template-kwargs
    if [[ ${REASONING:-0} -eq 1 ]]; then
      REASONING_ARGS=(--chat-template-kwargs '{"enable_thinking":true}')
    else
      REASONING_ARGS=(--chat-template-kwargs '{"enable_thinking":false}')
    fi
  elif [[ "${REASONING:-0}" -eq 1 ]]; then
    # Qwen3 uses reasoning-budget
    REASONING_ARGS=(--reasoning-budget -1)
  fi
fi

# API key
API_KEY_ARGS=()
[[ -n "$LLAMA_API_KEY" ]] && API_KEY_ARGS=(--api-key "$LLAMA_API_KEY")

# Speculative decoding
DRAFT_ARGS=()
if [[ $DRAFT -eq 1 ]]; then
  if [[ -n "${MODEL_DRAFT_PATH[$MODEL]+x}" ]]; then
    ensure_draft_model "$MODEL"
    DRAFT_ARGS=(--model-draft "${MODEL_DRAFT_PATH[$MODEL]}")
  else
    echo "Warning: no draft model configured for $MODEL, ignoring --draft"
  fi
fi

# Vision support
VISION_ARGS=()
if [[ $VISION -eq 1 ]]; then
  if [[ -n "${MODEL_MM_PROJ_PATH[$MODEL]+x}" ]]; then
    ensure_mmproj "$MODEL"
    VISION_ARGS=(--mmproj "${MODEL_MM_PROJ_PATH[$MODEL]}")
  else
    echo "Warning: no vision projector configured for $MODEL, ignoring --vision"
  fi
fi

# Check for existing process on the port
existing_pid=""
if command -v ss &>/dev/null; then
  existing_pid=$(ss -tlnp "sport = :$PORT" 2>/dev/null | grep -oP 'pid=\K[0-9]+' | head -1 || true)
elif command -v lsof &>/dev/null; then
  existing_pid=$(lsof -ti ":$PORT" 2>/dev/null | head -1 || true)
fi

if [[ -n "$existing_pid" ]]; then
  echo "Port $PORT is already in use by PID $existing_pid ($(ps -p "$existing_pid" -o comm= 2>/dev/null || echo unknown))."
  printf "Kill it and continue? [y/N] "
  read -r _answer
  case "$_answer" in
    [yY]*) kill "$existing_pid" && echo "Killed PID $existing_pid." || { echo "Failed to kill PID $existing_pid."; exit 1; } ;;
    *) echo "Cancelled."; exit 0 ;;
  esac
fi

# Launch
# shellcheck disable=SC2086
exec "$LLAMA_SERVER" \
  --threads "$LLAMA_THREADS" \
  --threads-batch "$LLAMA_THREADS_BATCH" \
  --threads-http "$LLAMA_THREADS_HTTP" \
  --parallel "$LLAMA_PARALLEL" \
  ${=MODEL_ARGS[$MODEL]} \
  "${HF_DOWNLOAD_ARGS[@]}" \
  "${REASONING_ARGS[@]}" \
  "${DRAFT_ARGS[@]}" \
  "${VISION_ARGS[@]}" \
  "${API_KEY_ARGS[@]}" \
  --host "$HOST" \
  --port "$PORT" \
  "${PASSTHRU[@]}"
