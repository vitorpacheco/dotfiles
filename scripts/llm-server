#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${LLAMA_SERVER:-}" ]]; then
  : # use env override as-is
elif command -v llama-server &>/dev/null; then
  LLAMA_SERVER="llama-server"
elif [[ -x "$HOME/applications/llama.cpp/build/bin/llama-server" ]]; then
  LLAMA_SERVER="$HOME/applications/llama.cpp/build/bin/llama-server"
else
  echo "Erro: llama-server não encontrado (PATH, ~/applications/llama.cpp/build/bin/, ou \$LLAMA_SERVER)"
  exit 1
fi

# ----------------------------
# Performance/parallelism knobs (defaults tuned for Ryzen 7 5700X)
# Override via env:
#   LLAMA_THREADS=8 LLAMA_THREADS_BATCH=12 LLAMA_THREADS_HTTP=4 LLAMA_PARALLEL=8 ./llm-server qwen
# ----------------------------
LLAMA_THREADS="${LLAMA_THREADS:-8}"
LLAMA_THREADS_BATCH="${LLAMA_THREADS_BATCH:-12}"
LLAMA_THREADS_HTTP="${LLAMA_THREADS_HTTP:-4}"
LLAMA_PARALLEL="${LLAMA_PARALLEL:-8}"

# ----------------------------
# Modelo registry (adicione/remova aqui)
# Cada modelo define:
#   - ARGS: flags específicas do modelo/preset
#   - DEFAULT_PORT: porta padrão
# ----------------------------

declare -A MODEL_ARGS=(
  # Qwen2.5 Coder 7B GGUF local
  [qwen2_5-coder]="
    -m $HOME/models/Qwen2.5-Coder-7B-Instruct-Q4_K_M.gguf
    --chat-template chatml
    --jinja
    --ctx-size 4096
    --batch-size 1024
    --ubatch-size 256
    --flash-attn
    --cache-type-k q8_0
    --cache-type-v q8_0
    --fit on
    --fit-target 1536
    --n-gpu-layers auto
  "

  # Qwen3.5 9B GGUF local
  [qwen3_5]="
    -m $HOME/models/Qwen_Qwen3.5-9B-Q4_K_M.gguf
    --jinja
    --ctx-size 8192
    --batch-size 1024
    --ubatch-size 256
    --flash-attn
    --cache-type-k q8_0
    --cache-type-v q8_0
    --n-gpu-layers auto
  "

  # GPT-OSS 20B preset (baixa os pesos automaticamente)
  [gpt-oss]="
    --gpt-oss-20b-default
    --ctx-size 4096
    --batch-size 1024
    --ubatch-size 256
    --flash-attn
    --cache-type-k q8_0
    --cache-type-v q8_0
    --fit on
    --fit-target 2048
    --n-gpu-layers auto
  "
)

declare -A MODEL_PORT=(
  [qwen2_5-coder]=8080
  [qwen3_5]=8082
  [gpt-oss]=8081
)

# HuggingFace source for auto-download: "owner/repo filename"
# Models without an entry (e.g. gpt-oss) are assumed to self-download
declare -A MODEL_HF=(
  [qwen2_5-coder]="Qwen/Qwen2.5-Coder-7B-Instruct-GGUF Qwen2.5-Coder-7B-Instruct-Q4_K_M.gguf"
  [qwen3_5]="bartowski/Qwen_Qwen3.5-9B-GGUF Qwen_Qwen3.5-9B-Q4_K_M.gguf"
)

# Local path for each model file
declare -A MODEL_PATH=(
  [qwen2_5-coder]="$HOME/models/Qwen2.5-Coder-7B-Instruct-Q4_K_M.gguf"
  [qwen3_5]="$HOME/models/Qwen_Qwen3.5-9B-Q4_K_M.gguf"
)

ensure_model() {
  local model="$1"
  [[ -z "${MODEL_PATH[$model]+x}" ]] && return 0

  local path="${MODEL_PATH[$model]}"
  [[ -f "$path" ]] && return 0

  if [[ -z "${MODEL_HF[$model]+x}" ]]; then
    echo "Erro: arquivo de modelo não encontrado: $path"
    exit 1
  fi

  local repo file
  read -r repo file <<< "${MODEL_HF[$model]}"
  echo "Modelo não encontrado. Baixando $file de $repo..."
  mkdir -p "$(dirname "$path")"

  if command -v huggingface-cli &>/dev/null; then
    huggingface-cli download "$repo" "$file" --local-dir "$(dirname "$path")"
  elif command -v wget &>/dev/null; then
    wget --continue "https://huggingface.co/$repo/resolve/main/$file" -O "$path"
  elif command -v curl &>/dev/null; then
    curl -L --continue-at - "https://huggingface.co/$repo/resolve/main/$file" -o "$path"
  else
    echo "Erro: instale huggingface-cli, wget ou curl para baixar o modelo"
    exit 1
  fi
}

usage() {
  cat <<EOF
Uso:
  llm-server <qwen2_5-coder|qwen3_5|gpt-oss> [--host 0.0.0.0] [--port N] [-- extra llama-server args...]

Env overrides (5700X defaults):
  LLAMA_THREADS=8
  LLAMA_THREADS_BATCH=12
  LLAMA_THREADS_HTTP=4
  LLAMA_PARALLEL=8

Exemplos:
  llm-server qwen2_5-coder
  llm-server qwen3_5
  LLAMA_PARALLEL=12 llm-server qwen3_5
  LLAMA_THREADS=10 LLAMA_THREADS_BATCH=16 llm-server qwen2_5-coder
  llm-server qwen2_5-coder --port 8080
  llm-server gpt-oss --host 0.0.0.0 --port 8081
  llm-server qwen3_5 -- --log-verbosity 4
EOF
}

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

MODEL="$1"
shift
if [[ -z "${MODEL_ARGS[$MODEL]+x}" ]]; then
  echo "Modelo inválido: $MODEL"
  usage
  exit 1
fi

ensure_model "$MODEL"

HOST="0.0.0.0"
PORT="${MODEL_PORT[$MODEL]}"

# Parse args simples do script; tudo depois de "--" vai direto pro llama-server
PASSTHRU=()
while [[ $# -gt 0 ]]; do
  case "$1" in
  --host)
    HOST="$2"
    shift 2
    ;;
  --port)
    PORT="$2"
    shift 2
    ;;
  --)
    shift
    PASSTHRU+=("$@")
    break
    ;;
  -h | --help)
    usage
    exit 0
    ;;
  *)
    echo "Arg desconhecido: $1"
    usage
    exit 1
    ;;
  esac
done

# Monta comando final
# shellcheck disable=SC2086
exec "$LLAMA_SERVER" \
  --host "$HOST" \
  --port "$PORT" \
  --threads "$LLAMA_THREADS" \
  --threads-batch "$LLAMA_THREADS_BATCH" \
  --threads-http "$LLAMA_THREADS_HTTP" \
  --parallel "$LLAMA_PARALLEL" \
  ${MODEL_ARGS[$MODEL]} \
  "${PASSTHRU[@]}"
