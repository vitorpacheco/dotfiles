#!/usr/bin/env bash
# =============================================================================
# llm-server — local LLM server launcher built on top of llama.cpp
#
# COMMANDS
#   setup               Clone/update llama.cpp and build it with CUDA support.
#                       Checks for required pacman packages, detects the CUDA
#                       toolkit, and compiles with flags tuned for this machine
#                       (Ryzen 7 5700X + RTX 3070 Ti, SM 8.6).
#
#   benchmark <model>   Measure inference throughput (t/s) for a model.
#                       Starts a temporary server, runs a fixed prompt N times,
#                       and reports tokens/second. If the model has a draft
#                       entry configured, also runs speculative decoding and
#                       reports the speedup. Controlled by:
#                         BENCH_REQUESTS=10   number of timed requests
#                         BENCH_N_PREDICT=256 tokens to generate per request
#
#   <model>             Start the llama-server for the given model. Downloads
#                       the GGUF file automatically if not present locally.
#
# MODEL FLAGS (for <model> command)
#   --host HOST         Bind address (default: 0.0.0.0)
#   --port N            Override the model's default port
#   --reasoning         Enable thinking/reasoning mode (Qwen3 family only)
#   --no-reasoning      Disable reasoning mode (default)
#   --draft             Enable speculative decoding with the model's draft model
#   --no-draft          Disable speculative decoding (default)
#   --update            Check HuggingFace for a newer GGUF and re-download
#   --                  Everything after this is passed directly to llama-server
#
# PERFORMANCE KNOBS (env overrides, tuned for Ryzen 7 5700X)
#   LLAMA_THREADS=8         inference threads (physical core count)
#   LLAMA_THREADS_BATCH=12  batch processing threads
#   LLAMA_THREADS_HTTP=4    HTTP handler threads
#   LLAMA_PARALLEL=8        concurrent inference slots
#   LLAMA_DIR               path to the llama.cpp checkout
#   LLAMA_SERVER            override the llama-server binary path
#
# MODEL REGISTRY
#   To add a new model, add entries to:
#     MODEL_ARGS    — llama-server flags (must include -m <path>)
#     MODEL_PORT    — default port
#     MODEL_PATH    — local GGUF path (for existence check / auto-download)
#     MODEL_HF      — "owner/repo filename" on HuggingFace (for download)
#   Optionally, for speculative decoding support:
#     MODEL_DRAFT_PATH — local path for the small draft GGUF
#     MODEL_DRAFT_HF   — "owner/repo filename" for the draft model
#   For reasoning mode support, add the model name to REASONING_MODELS.
# =============================================================================
set -euo pipefail

LLAMA_DIR="${LLAMA_DIR:-$HOME/applications/llama.cpp}"

# Skip binary detection for setup (binary may not exist yet)
if [[ "${1:-}" != "setup" ]]; then
  if [[ -n "${LLAMA_SERVER:-}" ]]; then
    : # use env override as-is
  elif command -v llama-server &>/dev/null; then
    LLAMA_SERVER="llama-server"
  elif [[ -x "$LLAMA_DIR/build/bin/llama-server" ]]; then
    LLAMA_SERVER="$LLAMA_DIR/build/bin/llama-server"
  else
    echo "Erro: llama-server não encontrado (PATH, $LLAMA_DIR/build/bin/, ou \$LLAMA_SERVER)"
    echo "Dica: rode 'llm-server setup' para compilar do zero"
    exit 1
  fi
fi

# ----------------------------
# Performance/parallelism knobs (defaults tuned for Ryzen 7 5700X)
# Override via env:
#   LLAMA_THREADS=8 LLAMA_THREADS_BATCH=12 LLAMA_THREADS_HTTP=4 LLAMA_PARALLEL=8 llm-server qwen3
# ----------------------------
LLAMA_THREADS="${LLAMA_THREADS:-8}"
LLAMA_THREADS_BATCH="${LLAMA_THREADS_BATCH:-12}"
LLAMA_THREADS_HTTP="${LLAMA_THREADS_HTTP:-4}"
LLAMA_PARALLEL="${LLAMA_PARALLEL:-8}"

# ----------------------------
# Model registry (adicione/remova aqui)
# ----------------------------

declare -A MODEL_ARGS=(
  # Qwen2.5 Coder 7B GGUF local
  [qwen2_5-coder]="
    -m $HOME/models/qwen2.5-coder-7b-instruct-q4_k_m.gguf
    --chat-template chatml
    --jinja
    --ctx-size 4096
    --batch-size 1024
    --ubatch-size 256
    --flash-attn on
    --cache-type-k q8_0
    --cache-type-v q8_0
    --fit on
    --fit-target 1536
    --n-gpu-layers auto
  "

  # Qwen3 8B GGUF local (standard transformer, full GPU support)
  [qwen3]="
    -m $HOME/models/Qwen3-8B-Q4_K_M.gguf
    --jinja
    --ctx-size 8192
    --batch-size 1024
    --ubatch-size 256
    --flash-attn on
    --cache-type-k q8_0
    --cache-type-v q8_0
    --n-gpu-layers auto
  "

  # Qwen3.5 9B GGUF local (hybrid DeltaNet arch — GPU support pending in llama.cpp)
  [qwen3_5]="
    -m $HOME/models/Qwen_Qwen3.5-9B-Q4_K_M.gguf
    --jinja
    --ctx-size 8192
    --batch-size 1024
    --ubatch-size 256
    --flash-attn on
    --cache-type-k q8_0
    --cache-type-v q8_0
    --n-gpu-layers auto
  "

  # GPT-OSS 20B preset (baixa os pesos automaticamente)
  # MoE: 20.9B total / 3.6B active params. --cpu-moe keeps expert weights in
  # RAM while attention layers stay on GPU, optimal for 8GB VRAM.
  [gpt-oss]="
    --gpt-oss-20b-default
    --ctx-size 4096
    --parallel 2
    --batch-size 1024
    --ubatch-size 256
    --flash-attn on
    --cache-type-k q8_0
    --cache-type-v q8_0
    --cpu-moe
    --n-gpu-layers auto
  "
)

declare -A MODEL_PORT=(
  [qwen2_5-coder]=8080
  [qwen3]=8083
  [qwen3_5]=8082
  [gpt-oss]=8081
)

# HuggingFace source for auto-download: "owner/repo filename"
# Models without an entry (e.g. gpt-oss) are assumed to self-download
declare -A MODEL_HF=(
  [qwen2_5-coder]="Qwen/Qwen2.5-Coder-7B-Instruct-GGUF qwen2.5-coder-7b-instruct-q4_k_m.gguf"
  [qwen3]="Qwen/Qwen3-8B-GGUF Qwen3-8B-Q4_K_M.gguf"
  [qwen3_5]="bartowski/Qwen_Qwen3.5-9B-GGUF Qwen_Qwen3.5-9B-Q4_K_M.gguf"
)

# Models that support reasoning/thinking mode (--reasoning-budget)
REASONING_MODELS=(qwen3 qwen3_5 gpt-oss)

# Local path for each model file
declare -A MODEL_PATH=(
  [qwen2_5-coder]="$HOME/models/qwen2.5-coder-7b-instruct-q4_k_m.gguf"
  [qwen3]="$HOME/models/Qwen3-8B-Q4_K_M.gguf"
  [qwen3_5]="$HOME/models/Qwen_Qwen3.5-9B-Q4_K_M.gguf"
)

# Draft models for speculative decoding (must share tokenizer with the target)
# Speculative decoding is most impactful when the target runs below ~15 t/s.
declare -A MODEL_DRAFT_HF=(
  [qwen2_5-coder]="Qwen/Qwen2.5-Coder-0.5B-Instruct-GGUF qwen2.5-coder-0.5b-instruct-q4_k_m.gguf"
  [qwen3]="Qwen/Qwen3-0.6B-GGUF Qwen3-0.6B-Q8_0.gguf"
)

declare -A MODEL_DRAFT_PATH=(
  [qwen2_5-coder]="$HOME/models/qwen2.5-coder-0.5b-instruct-q4_k_m.gguf"
  [qwen3]="$HOME/models/Qwen3-0.6B-Q8_0.gguf"
)

# =============================================================================
# Model management
# =============================================================================

download_model_file() {
  local repo="$1" file="$2" dest="$3"
  if command -v huggingface-cli &>/dev/null; then
    huggingface-cli download "$repo" "$file" --local-dir "$(dirname "$dest")"
  elif command -v wget &>/dev/null; then
    wget --continue "https://huggingface.co/$repo/resolve/main/$file" -O "$dest"
  elif command -v curl &>/dev/null; then
    curl -L --continue-at - "https://huggingface.co/$repo/resolve/main/$file" -o "$dest"
  else
    echo "Erro: instale huggingface-cli, wget ou curl para baixar o modelo"
    exit 1
  fi
}

hf_lfs_sha256() {
  local repo="$1" file="$2"
  command -v python3 &>/dev/null || return 1
  # limit=100 avoids pagination for large repos with many quant files
  local url="https://huggingface.co/api/models/$repo/tree/main?limit=100"
  local json
  if command -v curl &>/dev/null; then
    json=$(curl -sf "$url") || return 1
  elif command -v wget &>/dev/null; then
    json=$(wget -qO- "$url") || return 1
  else
    return 1
  fi
  echo "$json" | python3 -c "
import json, sys
try:
    for f in json.load(sys.stdin):
        if f.get('path') == '$file' and f.get('lfs'):
            oid = f['lfs']['oid']
            print(oid.split(':')[-1] if ':' in oid else oid)
            break
except: pass
" 2>/dev/null
}

ensure_model() {
  local model="$1"
  [[ -z "${MODEL_PATH[$model]+x}" ]] && return 0

  local path="${MODEL_PATH[$model]}"
  [[ -f "$path" ]] && return 0

  if [[ -z "${MODEL_HF[$model]+x}" ]]; then
    echo "Erro: arquivo de modelo não encontrado: $path"
    exit 1
  fi

  local repo file
  read -r repo file <<< "${MODEL_HF[$model]}"
  echo "Modelo não encontrado. Baixando $file de $repo..."
  mkdir -p "$(dirname "$path")"
  download_model_file "$repo" "$file" "$path"

  local sha
  sha=$(hf_lfs_sha256 "$repo" "$file")
  [[ -n "$sha" ]] && echo "$sha" > "${path}.sha256"
}

ensure_draft_model() {
  local model="$1"
  [[ -z "${MODEL_DRAFT_PATH[$model]+x}" ]] && return 0

  local path="${MODEL_DRAFT_PATH[$model]}"
  [[ -f "$path" ]] && return 0

  if [[ -z "${MODEL_DRAFT_HF[$model]+x}" ]]; then
    echo "Erro: draft model não encontrado: $path"
    exit 1
  fi

  local repo file
  read -r repo file <<< "${MODEL_DRAFT_HF[$model]}"
  echo "Draft model não encontrado. Baixando $file de $repo..."
  mkdir -p "$(dirname "$path")"
  download_model_file "$repo" "$file" "$path"

  local sha
  sha=$(hf_lfs_sha256 "$repo" "$file")
  [[ -n "$sha" ]] && echo "$sha" > "${path}.sha256"
}

update_model() {
  local model="$1"
  [[ -z "${MODEL_PATH[$model]+x}" ]] && return 0
  [[ -z "${MODEL_HF[$model]+x}" ]] && return 0

  local path="${MODEL_PATH[$model]}"
  local repo file
  read -r repo file <<< "${MODEL_HF[$model]}"

  echo "Verificando atualização para $model..."
  local remote_sha
  remote_sha=$(hf_lfs_sha256 "$repo" "$file")

  if [[ -z "$remote_sha" ]]; then
    echo "Aviso: não foi possível verificar versão remota (requer curl e python3)"
    return 0
  fi

  local local_sha=""
  [[ -f "${path}.sha256" ]] && local_sha=$(cat "${path}.sha256")

  if [[ "$remote_sha" == "$local_sha" ]]; then
    echo "$model: já está na versão mais recente (${remote_sha:0:8}...)"
    return 0
  fi

  if [[ -n "$local_sha" ]]; then
    echo "$model: atualização encontrada (${local_sha:0:8}... → ${remote_sha:0:8}...)"
  else
    echo "$model: baixando versão mais recente..."
  fi

  mkdir -p "$(dirname "$path")"
  [[ -f "$path" ]] && rm "$path"
  download_model_file "$repo" "$file" "$path"
  echo "$remote_sha" > "${path}.sha256"
  echo "$model: atualizado com sucesso"
}

# =============================================================================
# Benchmark
# =============================================================================

_bench_http() {
  local url="$1" payload="$2"
  if command -v curl &>/dev/null; then
    curl -sf --max-time 300 -X POST "$url" \
      -H "Content-Type: application/json" -d "$payload"
  else
    wget -qO- --timeout=300 --post-data="$payload" \
      --header="Content-Type: application/json" "$url"
  fi
}

_bench_wait() {
  local base_url="$1"
  echo -n "  Aguardando servidor"
  for _ in $(seq 1 90); do
    local r
    if command -v curl &>/dev/null; then
      r=$(curl -sf --max-time 2 "$base_url/health" 2>/dev/null) || true
    else
      r=$(wget -qO- --timeout=2 "$base_url/health" 2>/dev/null) || true
    fi
    if echo "$r" | grep -q '"status":"ok"'; then echo " ok"; return 0; fi
    echo -n "."; sleep 2
  done
  echo " timeout"; return 1
}

_bench_run() {
  local base_url="$1" n="$2" n_predict="$3"
  local prompt="Explain in detail how attention mechanisms work in transformer neural networks, covering self-attention, multi-head attention, positional encodings, and the training process."
  local payload="{\"prompt\":\"$prompt\",\"n_predict\":$n_predict,\"temperature\":0}"
  local tmp
  tmp=$(mktemp -d)

  # warmup
  _bench_http "$base_url/completion" "$payload" > /dev/null 2>&1 || true

  for i in $(seq 1 "$n"); do
    _bench_http "$base_url/completion" "$payload" > "$tmp/r$i.json" 2>/dev/null || true
  done

  python3 - "$tmp" <<'PYEOF'
import json, sys, os, glob
total_tokens = total_ms = count = 0
for f in glob.glob(os.path.join(sys.argv[1], '*.json')):
    try:
        d = json.load(open(f))
        t = d.get('timings', {})
        total_tokens += t.get('predicted_n', 0)
        total_ms += t.get('predicted_ms', 0.0)
        count += 1
    except: pass
if total_ms > 0:
    tps = total_tokens / (total_ms / 1000)
    print(f"{tps:.1f} t/s  ({total_tokens} tokens, {count} req)")
else:
    print("N/A")
PYEOF
  rm -rf "$tmp"
}

benchmark_model() {
  local model="$1"
  local port=19999
  local base_url="http://127.0.0.1:$port"
  local n="${BENCH_REQUESTS:-10}"
  local n_predict="${BENCH_N_PREDICT:-256}"

  if [[ -z "${MODEL_ARGS[$model]+x}" ]]; then
    echo "Modelo inválido: $model"; usage; exit 1
  fi

  ensure_model "$model"

  # Always disable reasoning for consistent benchmark results
  local reasoning_args=()
  if printf '%s\n' "${REASONING_MODELS[@]}" | grep -qx "$model"; then
    reasoning_args=(--reasoning-budget 0)
  fi

  local has_draft=0
  [[ -n "${MODEL_DRAFT_PATH[$model]+x}" ]] && has_draft=1
  local total_runs=$(( 1 + has_draft ))

  echo ""
  echo "=== Benchmark: $model ==="
  echo "    $n requisições × $n_predict tokens"

  # --- baseline ---
  echo ""
  echo "[ 1/$total_runs ] Baseline (sem draft)"
  local server_pid
  # shellcheck disable=SC2086
  "$LLAMA_SERVER" \
    --threads "$LLAMA_THREADS" --threads-batch "$LLAMA_THREADS_BATCH" \
    --threads-http "$LLAMA_THREADS_HTTP" --parallel 1 \
    --log-disable \
    ${MODEL_ARGS[$model]} \
    --host 127.0.0.1 --port "$port" \
    "${reasoning_args[@]}" > /dev/null 2>&1 &
  server_pid=$!

  if ! _bench_wait "$base_url"; then
    kill "$server_pid" 2>/dev/null; return 1
  fi

  local baseline
  baseline=$(_bench_run "$base_url" "$n" "$n_predict")
  echo "  Resultado: $baseline"
  kill "$server_pid" 2>/dev/null; wait "$server_pid" 2>/dev/null

  # --- speculative decoding ---
  if [[ $has_draft -eq 1 ]]; then
    ensure_draft_model "$model"
    local draft_path="${MODEL_DRAFT_PATH[$model]}"

    echo ""
    echo "[ 2/2 ] Com draft model ($(basename "$draft_path"))"
    # shellcheck disable=SC2086
    "$LLAMA_SERVER" \
      --host 127.0.0.1 --port "$port" \
      --threads "$LLAMA_THREADS" --threads-batch "$LLAMA_THREADS_BATCH" \
      --threads-http "$LLAMA_THREADS_HTTP" --parallel 1 \
      --log-disable \
      --model-draft "$draft_path" \
      ${MODEL_ARGS[$model]} \
      "${reasoning_args[@]}" > /dev/null 2>&1 &
    server_pid=$!

    if ! _bench_wait "$base_url"; then
      kill "$server_pid" 2>/dev/null; return 1
    fi

    local draft_result
    draft_result=$(_bench_run "$base_url" "$n" "$n_predict")
    echo "  Resultado: $draft_result"
    kill "$server_pid" 2>/dev/null; wait "$server_pid" 2>/dev/null

    python3 -c "
b = float('$baseline'.split()[0]) if '$baseline' != 'N/A' else 0
d = float('$draft_result'.split()[0]) if '$draft_result' != 'N/A' else 0
if b > 0 and d > 0:
    pct = (d - b) / b * 100
    sign = '+' if pct >= 0 else ''
    print(f'  Speedup:  {sign}{pct:.1f}%')
" 2>/dev/null
  fi

  echo ""
  echo "==================================="
}

# =============================================================================
# Setup
# =============================================================================

setup_llama() {
  local build_deps=(git cmake ninja cuda)
  local missing=()
  for pkg in "${build_deps[@]}"; do
    pacman -Q "$pkg" &>/dev/null || missing+=("$pkg")
  done
  # base-devel proxy check
  command -v gcc &>/dev/null || missing+=(base-devel)

  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Pacotes necessários não encontrados: ${missing[*]}"
    sudo pacman -S --needed "${missing[@]}"
  fi

  if command -v nvidia-smi &>/dev/null && nvidia-smi &>/dev/null; then
    echo "GPU NVIDIA detectada:"
    nvidia-smi --query-gpu=name,driver_version,memory.total --format=csv,noheader
  else
    echo "Aviso: nvidia-smi não encontrado ou falhou."
    echo "  O driver NVIDIA pode não estar instalado ou carregado."
    echo "  A compilação continuará, mas sem suporte a CUDA/GPU."
  fi

  if [[ ! -d "$LLAMA_DIR" ]]; then
    echo "Clonando llama.cpp em $LLAMA_DIR..."
    git clone https://github.com/ggml-org/llama.cpp "$LLAMA_DIR"
  else
    echo "Atualizando llama.cpp..."
    git -C "$LLAMA_DIR" pull
  fi

  # Locate CUDA toolkit (Arch installs to /opt/cuda, not in PATH by default)
  local cuda_root=""
  if command -v nvcc &>/dev/null; then
    cuda_root="$(dirname "$(dirname "$(command -v nvcc)")")"
  else
    for candidate in /opt/cuda /usr/local/cuda /usr/lib/cuda; do
      if [[ -x "$candidate/bin/nvcc" ]]; then
        cuda_root="$candidate"
        break
      fi
    done
  fi

  local cuda_flags=()
  if [[ -n "$cuda_root" ]]; then
    echo "CUDA toolkit encontrado em: $cuda_root"
    cuda_flags=(
      -DGGML_CUDA=ON
      -DCUDAToolkit_ROOT="$cuda_root"
      -DCMAKE_CUDA_COMPILER="$cuda_root/bin/nvcc"
      -DCMAKE_CUDA_ARCHITECTURES=86
      -DGGML_CUDA_FA_ALL_QUANTS=ON
    )
  else
    echo "Aviso: CUDA toolkit (nvcc) não encontrado. Compilando sem suporte a GPU."
    echo "  Instale o pacote 'cuda' e tente novamente: sudo pacman -S cuda"
  fi

  echo "Compilando para Ryzen 7 5700X + RTX 3070 Ti (SM 8.6)..."
  cmake -S "$LLAMA_DIR" -B "$LLAMA_DIR/build" \
    -DCMAKE_BUILD_TYPE=Release \
    "${cuda_flags[@]}" \
    -DGGML_NATIVE=ON \
    -GNinja

  cmake --build "$LLAMA_DIR/build" --config Release -j"$(nproc)"
  echo "Concluído: $LLAMA_DIR/build/bin/llama-server"
}

# =============================================================================
# Usage
# =============================================================================

usage() {
  cat <<EOF
Uso:
  llm-server setup
  llm-server benchmark <model>
  llm-server <model> [flags] [-- extra llama-server args...]

Modelos: qwen2_5-coder | qwen3 | qwen3_5 | gpt-oss

Comandos:
  setup               clone/update llama.cpp and build with CUDA (RTX 3070 Ti + 5700X)
  benchmark <model>   measure throughput with and without speculative decoding

Flags:
  --reasoning         enable reasoning/thinking mode (Qwen3 family only)
  --no-reasoning      disable reasoning/thinking mode (default)
  --draft             enable speculative decoding with the model's draft model
  --no-draft          disable speculative decoding (default)
  --update            check for a newer GGUF on HuggingFace and re-download if found
  --host HOST         bind address (default: 0.0.0.0)
  --port N            override default port

Env overrides (5700X defaults):
  LLAMA_THREADS=8       LLAMA_THREADS_BATCH=12
  LLAMA_THREADS_HTTP=4  LLAMA_PARALLEL=8
  LLAMA_DIR=$HOME/applications/llama.cpp
  BENCH_REQUESTS=10     BENCH_N_PREDICT=256

Exemplos:
  llm-server setup
  llm-server benchmark qwen3
  llm-server qwen3
  llm-server qwen3 --draft
  llm-server qwen3 --reasoning
  llm-server qwen3 --update
  llm-server qwen2_5-coder --port 8080
  llm-server qwen3 -- --log-verbosity 4
EOF
}

# =============================================================================
# Main
# =============================================================================

if [[ $# -lt 1 ]]; then
  usage; exit 1
fi

if [[ "$1" == "setup" ]]; then
  setup_llama; exit 0
fi

if [[ "$1" == "benchmark" ]]; then
  [[ $# -lt 2 ]] && { echo "Uso: llm-server benchmark <model>"; exit 1; }
  benchmark_model "$2"; exit 0
fi

MODEL="$1"
shift
if [[ -z "${MODEL_ARGS[$MODEL]+x}" ]]; then
  echo "Modelo inválido: $MODEL"; usage; exit 1
fi

HOST="0.0.0.0"
PORT="${MODEL_PORT[$MODEL]}"
REASONING=0
DRAFT=0
UPDATE=0

# Parse script args; everything after "--" is passed directly to llama-server
PASSTHRU=()
while [[ $# -gt 0 ]]; do
  case "$1" in
  --host)         HOST="$2";    shift 2 ;;
  --port)         PORT="$2";    shift 2 ;;
  --reasoning)    REASONING=1;  shift   ;;
  --no-reasoning) REASONING=0;  shift   ;;
  --draft)        DRAFT=1;      shift   ;;
  --no-draft)     DRAFT=0;      shift   ;;
  --update)       UPDATE=1;     shift   ;;
  --)             shift; PASSTHRU+=("$@"); break ;;
  -h|--help)      usage; exit 0 ;;
  *)              echo "Arg desconhecido: $1"; usage; exit 1 ;;
  esac
done

if [[ $UPDATE -eq 1 ]]; then
  update_model "$MODEL"
fi
ensure_model "$MODEL"

# Reasoning budget
REASONING_ARGS=()
if printf '%s\n' "${REASONING_MODELS[@]}" | grep -qx "$MODEL"; then
  [[ $REASONING -eq 0 ]] && REASONING_ARGS=(--reasoning-budget 0)
fi

# Speculative decoding
DRAFT_ARGS=()
if [[ $DRAFT -eq 1 ]]; then
  if [[ -n "${MODEL_DRAFT_PATH[$MODEL]+x}" ]]; then
    ensure_draft_model "$MODEL"
    DRAFT_ARGS=(--model-draft "${MODEL_DRAFT_PATH[$MODEL]}")
  else
    echo "Aviso: nenhum draft model configurado para $MODEL, ignorando --draft"
  fi
fi

# Launch
# shellcheck disable=SC2086
exec "$LLAMA_SERVER" \
  --threads "$LLAMA_THREADS" \
  --threads-batch "$LLAMA_THREADS_BATCH" \
  --threads-http "$LLAMA_THREADS_HTTP" \
  --parallel "$LLAMA_PARALLEL" \
  ${MODEL_ARGS[$MODEL]} \
  "${REASONING_ARGS[@]}" \
  "${DRAFT_ARGS[@]}" \
  --host "$HOST" \
  --port "$PORT" \
  "${PASSTHRU[@]}"
