#!/usr/bin/env bash

# AI Agents Updater Script
# Updates: claude code, codex, opencode, qwen coder, kimi code, aider, gemini, pi coding agent, cursor, antigravity, kiro ide, kiro cli, windsurf

set -uo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'

# Counters
TOTAL_AGENTS=13
UPDATED=0
ALREADY_LATEST=0
SKIPPED=0
FAILED=0
APPROVE_MACOS=false

TOOLS="claude codex opencode qwen gemini aider kimi pi cursor windsurf antigravity kiro kiro-cli"

# Detect OS/distro
detect_os() {
    if [[ "$(uname -s 2>/dev/null)" == "Darwin" ]]; then
        echo "macos"
        return
    fi

    if [ -f /etc/os-release ]; then
        . /etc/os-release
        local id_like="${ID_LIKE:-}"
        if [[ "$ID" == "ubuntu" ]] || [[ "$ID" == "debian" ]] || [[ "$id_like" == *"debian"* ]] || [[ "$id_like" == *"ubuntu"* ]]; then
            echo "debian"
        elif [[ "$ID" == "arch" ]] || [[ "$id_like" == *"arch"* ]]; then
            echo "arch"
        else
            echo "unknown"
        fi
    else
        echo "unknown"
    fi
}

OS_TYPE=$(detect_os)

# Check if package is installed via system package manager
check_system_package() {
    local pkg_name=$1
    local os_type=$2

    case $os_type in
        "debian")
            dpkg -l "$pkg_name" 2>/dev/null | grep -q "^ii"
            ;;
        "arch")
            pacman -Q "$pkg_name" 2>/dev/null | grep -q "^$pkg_name"
            ;;
        "macos")
            if command -v brew &> /dev/null; then
                brew list --formula "$pkg_name" >/dev/null 2>&1 || brew list --cask "$pkg_name" >/dev/null 2>&1
            else
                return 1
            fi
            ;;
        *)
            return 1
            ;;
    esac
}

# Check if an Arch package has a newer version available
has_arch_update() {
    local pkg_name=$1

    if command -v yay &> /dev/null; then
        yay -Qu "$pkg_name" 2>/dev/null | grep -q "^$pkg_name "
    elif command -v paru &> /dev/null; then
        paru -Qu "$pkg_name" 2>/dev/null | grep -q "^$pkg_name "
    else
        pacman -Qu "$pkg_name" 2>/dev/null | grep -q "^$pkg_name "
    fi
}

# Check if an npm global package has a newer version available
has_npm_update() {
    local pkg_name=$1

    if ! command -v npm &> /dev/null; then
        return 1
    fi

    local outdated
    outdated="$(npm outdated -g "$pkg_name" --json 2>/dev/null || true)"
    [ -n "$outdated" ] && [ "$outdated" != "{}" ]
}

# Update system package
update_system_package() {
    local pkg_name=$1
    local os_type=$2

    case $os_type in
        "debian")
            echo -e "  ${DIM}Package manager:${NC} apt"
            echo -e "  ${DIM}Running:${NC} sudo apt update && sudo apt upgrade $pkg_name"
            sudo apt update 2>&1 | while read line; do
                echo -e "  ${DIM}>${NC} $line"
            done
            sudo apt upgrade -y "$pkg_name" 2>&1 | while read line; do
                echo -e "  ${DIM}>${NC} $line"
            done
            ;;
        "arch")
            if command -v yay &> /dev/null; then
                echo -e "  ${DIM}Package manager:${NC} yay (AUR helper)"
                if has_arch_update "$pkg_name"; then
                    echo -e "  ${DIM}Running:${NC} yay -S --needed $pkg_name"
                    yay -S --needed --noconfirm "$pkg_name" 2>&1 | while read line; do
                        echo -e "  ${DIM}>${NC} $line"
                    done
                else
                    echo -e "  ${DIM}>${NC} No newer version available for $pkg_name"
                fi
            elif command -v paru &> /dev/null; then
                echo -e "  ${DIM}Package manager:${NC} paru (AUR helper)"
                if has_arch_update "$pkg_name"; then
                    echo -e "  ${DIM}Running:${NC} paru -S --needed $pkg_name"
                    paru -S --needed --noconfirm "$pkg_name" 2>&1 | while read line; do
                        echo -e "  ${DIM}>${NC} $line"
                    done
                else
                    echo -e "  ${DIM}>${NC} No newer version available for $pkg_name"
                fi
            else
                echo -e "  ${DIM}Package manager:${NC} pacman"
                if has_arch_update "$pkg_name"; then
                    echo -e "  ${DIM}Running:${NC} sudo pacman -S --needed $pkg_name"
                    sudo pacman -S --needed --noconfirm "$pkg_name" 2>&1 | while read line; do
                        echo -e "  ${DIM}>${NC} $line"
                    done
                else
                    echo -e "  ${DIM}>${NC} No newer version available for $pkg_name"
                fi
            fi
            ;;
        "macos")
            if command -v brew &> /dev/null; then
                echo -e "  ${DIM}Package manager:${NC} brew"
                echo -e "  ${DIM}Running:${NC} brew upgrade $pkg_name"
                brew upgrade "$pkg_name" 2>&1 | while read line; do
                    echo -e "  ${DIM}>${NC} $line"
                done
            else
                echo -e "  ${RED}✗${NC} ${RED}Homebrew not found${NC}"
                return 1
            fi
            ;;
    esac
}

# Get version from command
get_version() {
    local cmd=$1
    $cmd --version 2>/dev/null | grep -Eo '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || echo "unknown"
}

approve_macos_binary() {
    local agent_name=$1
    local cmd_name=$2

    if [[ "$APPROVE_MACOS" != "true" ]] || [[ "$OS_TYPE" != "macos" ]]; then
        return
    fi

    if ! command -v xattr &> /dev/null; then
        echo -e "  ${YELLOW}⚠${NC} ${YELLOW}xattr not found${NC} (cannot auto-approve ${agent_name})"
        return
    fi

    local bin_path
    bin_path="$(command -v "$cmd_name" 2>/dev/null || true)"

    if [ -z "$bin_path" ]; then
        return
    fi

    if xattr -p com.apple.quarantine "$bin_path" >/dev/null 2>&1; then
        if xattr -d com.apple.quarantine "$bin_path" >/dev/null 2>&1; then
            echo -e "  ${GREEN}✓${NC} ${GREEN}Auto-approved${NC} ${agent_name} (${bin_path})"
        else
            echo -e "  ${YELLOW}⚠${NC} ${YELLOW}Could not auto-approve${NC} ${agent_name} (${bin_path})"
        fi
    fi
}

# Print agent header
print_agent_start() {
    local agent=$1
    local action=$2
    echo -e "\n${CYAN}${BOLD}▶${NC} ${BOLD}${agent}${NC} ${DIM}→${NC} ${action}"
}

# Print agent result
print_agent_result() {
    local status=$1
    local message=$2

    case $status in
        "updated")
            echo -e "  ${GREEN}✓${NC} ${GREEN}Updated${NC} ${message}"
            ;;
        "latest")
            echo -e "  ${BLUE}●${NC} ${BLUE}Already latest${NC} ${message}"
            ;;
        "skipped")
            echo -e "  ${YELLOW}⊘${NC} ${YELLOW}Not installed${NC}"
            ;;
        "failed")
            echo -e "  ${RED}✗${NC} ${RED}Failed${NC} ${message}"
            ;;
        "self-managed")
            echo -e "  ${MAGENTA}⚙${NC} ${MAGENTA}Self-managed${NC} ${message}"
            ;;
    esac
}

# Update functions

update_claude() {
    print_agent_start "Claude Code" "checking and updating"

    if command -v claude &> /dev/null; then
        echo -e "  ${DIM}Current:${NC} $(claude --version 2>/dev/null | head -1)"

        # Check if installed via package manager
        if check_system_package "claude-code" "$OS_TYPE" || check_system_package "claude" "$OS_TYPE"; then
            echo -e "  ${DIM}Installation:${NC} System package"
            local old_version=$(get_version "claude")
            update_system_package "claude-code" "$OS_TYPE"
            local new_version=$(get_version "claude")
            if [ "$old_version" != "$new_version" ] && [ "$new_version" != "unknown" ]; then
                print_agent_result "updated" "($old_version → $new_version)"
                UPDATED=$((UPDATED + 1))
            else
                print_agent_result "latest" "($new_version)"
                ALREADY_LATEST=$((ALREADY_LATEST + 1))
            fi
        else
            echo -e "  ${DIM}Installation:${NC} Self-managed binary"
            echo -e "  ${DIM}Running:${NC} claude update"
            local old_version=$(get_version "claude")
            if claude update 2>&1 | grep -v "^$"; then
                local new_version=$(get_version "claude")
                if [ "$old_version" != "$new_version" ] && [ "$new_version" != "unknown" ]; then
                    print_agent_result "updated" "($old_version → $new_version)"
                    UPDATED=$((UPDATED + 1))
                else
                    print_agent_result "latest" "($new_version)"
                    ALREADY_LATEST=$((ALREADY_LATEST + 1))
                fi
            else
                print_agent_result "failed" "(update command failed)"
                FAILED=$((FAILED + 1))
            fi
        fi

        approve_macos_binary "Claude Code" "claude"
    else
        print_agent_result "skipped" ""
        SKIPPED=$((SKIPPED + 1))
    fi
}

